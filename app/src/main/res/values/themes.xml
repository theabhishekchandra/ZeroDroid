<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ZeroDroid" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
    </style>

    <!-- Splash screen theme (Android 12+ SplashScreen API compat) -->
    <style name="Theme.ZeroDroid.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.ZeroDroid</item>
    </style>
</resources>
